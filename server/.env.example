# ===================================================================
# Nairobi Transit Payment System — Environment Configuration
# ===================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ===================================================================

# Server
HOST=0.0.0.0
PORT=8080
RUST_LOG=info

# ── Database (DigitalOcean Managed PostgreSQL) ────────────────────
# Local dev:  postgres://transit:transit@localhost:5432/nairobi_transit
# DO prod:    postgres://doadmin:<password>@<host>.k.db.ondigitalocean.com:25060/transitdb?sslmode=require
DATABASE_URL=postgres://transit:transit@localhost:5432/nairobi_transit

# ── Redis (Azure Cache for Redis) ────────────────────────────────
# Local dev:  redis://localhost:6379
# Azure prod: rediss://:<access-key>@<name>.southafricanorth.redis.azure.net:10000
REDIS_URL=redis://localhost:6379

# ── Daraja (M-Pesa) ─────────────────────────────────────────────
# Sandbox:    https://sandbox.safaricom.co.ke  — test shortcode 174379
# Production: https://api.safaricom.co.ke
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
# Sandbox passkey (use your own in production):
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Sandbox shortcode (use your SACCO paybill in production):
DARAJA_SHORTCODE=174379
DARAJA_CALLBACK_URL=https://yourdomain.com/api/daraja/callback

# ── Africa's Talking ─────────────────────────────────────────────
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key
AT_USSD_CODE=*384#
AT_SENDER_ID=TRANSIT

# ── JWT secret for conductor auth ────────────────────────────────
JWT_SECRET=your_very_long_random_secret_here

# ── QR base URL (what passengers scan) ──────────────────────────
QR_BASE_URL=https://yourdomain.com/pay
